<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculator</title>
<style>
    /* Black and Orange Theme */
    body {
        background-color: #121212;
        color: #ffffff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }
    
    .calculator {
        background-color: #1e1e1e;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        width: 320px;
        padding: 20px;
        border: 2px solid #ff6600; /* Orange accent */
    }
    
    .display {
        background-color: #000000;
        color: #ff6600;
        font-size: 2.5em;
        text-align: right;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 1px solid #333;
        min-height: 50px;
        word-wrap: break-word;
        font-family: monospace;
    }
    
    .buttons {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }
    
    button {
        background-color: #2c2c2c;
        color: #ffffff;
        border: none;
        padding: 20px;
        font-size: 1.5em;
        border-radius: 10px;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.1s;
    }
    
    button:active { transform: scale(0.95); }
    button:hover { background-color: #3c3c3c; }
    
    .operator { 
        background-color: #ff6600; 
        color: #000; 
        font-weight: bold; 
    }
    
    .operator:hover { background-color: #cc5200; }
    .span-2 { grid-column: span 2; }
    
    /* --- Secret Vault Styles --- */
    .vault {
        display: none; /* Hidden by default */
        background-color: #1e1e1e;
        border-radius: 15px;
        width: 320px;
        padding: 30px 20px;
        text-align: center;
        border: 2px solid #ff6600;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    }
    
    .vault h2 { 
        color: #ff6600; 
        margin-top: 0;
    }
    
    .vault p { color: #aaaaaa; }
    
    .file-input-container {
        margin: 30px 0;
        padding: 20px;
        border: 2px dashed #444;
        border-radius: 10px;
    }
    
    .close-vault { 
        background-color: #ff6600; 
        color: #000; 
        font-weight: bold; 
        padding: 15px 30px; 
        border-radius: 8px; 
        cursor: pointer; 
        width: 100%;
        font-size: 1.2em;
    }
</style>
</head>
<body>

<div class="calculator" id="calculator">
    <div class="display" id="display"></div>
    <div class="buttons">
        <button class="span-2" onclick="clearDisplay()">C</button>
        <button class="operator" onclick="appendValue('/')">÷</button>
        <button class="operator" onclick="appendValue('*')">×</button>
        
        <button onclick="appendValue('7')">7</button>
        <button onclick="appendValue('8')">8</button>
        <button onclick="appendValue('9')">9</button>
        <button class="operator" onclick="appendValue('-')">-</button>
        
        <button onclick="appendValue('4')">4</button>
        <button onclick="appendValue('5')">5</button>
        <button onclick="appendValue('6')">6</button>
        <button class="operator" onclick="appendValue('+')">+</button>
        
        <button onclick="appendValue('1')">1</button>
        <button onclick="appendValue('2')">2</button>
        <button onclick="appendValue('3')">3</button>
        <button class="operator" style="grid-row: span 2;" onclick="calculate()">=</button>
        
        <button class="span-2" onclick="appendValue('0')">0</button>
        <button onclick="appendValue('.')">.</button>
    </div>
</div>

<div class="vault" id="vault">
    <h2>🔒 Secret Vault</h2>
    <p>Welcome to your hidden storage.</p>
    
    <div class="file-input-container">
        <input type="file" multiple accept="image/*" style="color: white; width: 100%;">
    </div>
    
    <button class="close-vault" onclick="closeVault()">Lock & Exit</button>
</div>

<script>
    const display = document.getElementById('display');
    const calculator = document.getElementById('calculator');
    const vault = document.getElementById('vault');
    
    // Here is your secret code!
    const secretCode = '77797-20';

    function appendValue(val) {
        display.innerText += val;
    }

    function clearDisplay() {
        display.innerText = '';
    }

    function calculate() {
        const currentInput = display.innerText;
        
        // --- THE SECRET TRIGGER ---
        if (currentInput === secretCode) {
            calculator.style.display = 'none'; // Hide calculator
            vault.style.display = 'block';     // Show vault
            clearDisplay();
            return;
        }

        // --- NORMAL CALCULATOR LOGIC ---
        try {
            // Replace visual symbols with math operators before calculating
            let mathString = currentInput.replace(/÷/g, '/').replace(/×/g, '*');
            let result = eval(mathString);
            
            // Handle cases where the result is undefined or empty
            if (result === undefined) {
                clearDisplay();
            } else {
                display.innerText = result;
            }
        } catch (error) {
            display.innerText = 'Error';
            setTimeout(clearDisplay, 1500); // Clear error after 1.5 seconds
        }
    }

    function closeVault() {
        // Return to normal calculator mode
        vault.style.display = 'none';
        calculator.style.display = 'block';
    }
</script>
</body>
</html>
