<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cosmic Music Player</title>
<style>
    /* Deep Space Theme */
    body {
        margin: 0;
        padding: 0;
        background-color: #050510;
        color: #ffffff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden; /* Hide scrollbars for the 3D canvas */
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    /* 3D Canvas Background */
    #space-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    /* Glassmorphism Player UI */
    .player-container {
        position: relative;
        z-index: 10;
        background: rgba(15, 15, 30, 0.7);
        backdrop-filter: blur(15px);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding: 20px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.8);
    }

    .now-playing {
        font-size: 1.2em;
        font-weight: bold;
        color: #00d2ff; /* Neon blue */
        margin-bottom: 10px;
        text-shadow: 0 0 10px rgba(0, 210, 255, 0.5);
    }

    /* Controls */
    .controls {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
        width: 100%;
        max-width: 600px;
    }

    button {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 10px 20px;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: bold;
    }

    button:hover {
        background: rgba(0, 210, 255, 0.3);
        border-color: #00d2ff;
        box-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
    }

    /* Progress Bar */
    .progress-container {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 15px;
        font-size: 0.9em;
        color: #aaaaaa;
    }

    input[type="range"] {
        flex-grow: 1;
        cursor: pointer;
        accent-color: #00d2ff;
    }

    /* Playlist Overlay */
    .playlist-panel {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 300px;
        max-height: 60vh;
        background: rgba(10, 10, 20, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 15px;
        padding: 15px;
        z-index: 10;
        overflow-y: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .playlist-panel h3 {
        margin-top: 0;
        color: #00d2ff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 10px;
    }

    .track-item {
        padding: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        cursor: pointer;
        transition: background 0.2s;
        font-size: 0.9em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .track-item:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .active-track {
        color: #00d2ff;
        font-weight: bold;
    }

    /* File Input Styling */
    .file-upload {
        margin-bottom: 15px;
    }
    
    .file-upload input {
        width: 100%;
        font-size: 0.8em;
    }
    
    /* Custom Scrollbar for playlist */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
    ::-webkit-scrollbar-thumb { background: #00d2ff; border-radius: 4px; }
</style>
</head>
<body>

<canvas id="space-canvas"></canvas>

<div class="playlist-panel">
    <h3>🌌 Orbiting Tracks</h3>
    <div class="file-upload">
        <label for="audio-upload" style="font-size: 0.8em; color: #aaa;">Load your 20+ songs here:</label><br><br>
        <input type="file" id="audio-upload" multiple accept="audio/*">
    </div>
    <div id="playlist-container">
        <div style="color: #666; font-size: 0.9em; text-align: center; margin-top: 20px;">
            No tracks loaded. Select files above to populate your universe.
        </div>
    </div>
</div>

<div class="player-container">
    <div class="now-playing" id="now-playing">Awaiting Audio Signal...</div>
    
    <div class="controls">
        <button id="prev-btn">⏮ Prev</button>
        <button id="play-btn">▶ Play</button>
        <button id="next-btn">Next ⏭</button>
        
        <div class="progress-container">
            <span id="current-time">0:00</span>
            <input type="range" id="seek-bar" value="0" min="0" step="1">
            <span id="duration">0:00</span>
        </div>
    </div>
</div>

<audio id="audio-player"></audio>

<script>
    // --- 1. UI AND AUDIO PLAYER LOGIC ---
    const audioPlayer = document.getElementById('audio-player');
    const playBtn = document.getElementById('play-btn');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const seekBar = document.getElementById('seek-bar');
    const currentTimeEl = document.getElementById('current-time');
    const durationEl = document.getElementById('duration');
    const nowPlayingEl = document.getElementById('now-playing');
    const audioUpload = document.getElementById('audio-upload');
    const playlistContainer = document.getElementById('playlist-container');

    let playlist = [];
    let currentTrackIndex = 0;
    let isPlaying = false;
    
    // Audio Context for Visualization
    let audioCtx, analyser, dataArray;
    let audioSource;
    let isAudioInitialized = false;

    // Format time (e.g., 65 seconds -> 1:05)
    function formatTime(seconds) {
        if (isNaN(seconds)) return "0:00";
        const mins = Math.floor(seconds / 60);
        const secs = Math.floor(seconds % 60);
        return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
    }

    // Load files into playlist
    audioUpload.addEventListener('change', function(e) {
        const files = Array.from(e.target.files);
        if (files.length === 0) return;

        playlist = files;
        currentTrackIndex = 0;
        renderPlaylist();
        loadTrack(currentTrackIndex);
    });

    function renderPlaylist() {
        playlistContainer.innerHTML = '';
        playlist.forEach((file, index) => {
            const trackDiv = document.createElement('div');
            trackDiv.className = `track-item ${index === currentTrackIndex ? 'active-track' : ''}`;
            trackDiv.innerText = `${index + 1}. ${file.name.replace(/\.[^/.]+$/, "")}`; // Remove extension
            trackDiv.onclick = () => {
                currentTrackIndex = index;
                loadTrack(currentTrackIndex);
                playAudio();
            };
            playlistContainer.appendChild(trackDiv);
        });
    }

    function loadTrack(index) {
        if (playlist.length === 0) return;
        
        const file = playlist[index];
        const objectUrl = URL.createObjectURL(file);
        audioPlayer.src = objectUrl;
        nowPlayingEl.innerText = file.name.replace(/\.[^/.]+$/, "");
        renderPlaylist(); // Update active class
    }

    // Initialize Web Audio API (Must be done after a user click)
    function initAudioContext() {
        if (isAudioInitialized) return;
        
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        analyser = audioCtx.createAnalyser();
        
        // Connect audio element to analyser, then to speakers
        audioSource = audioCtx.createMediaElementSource(audioPlayer);
        audioSource.connect(analyser);
        analyser.connect(audioCtx.destination);
        
        // Set up array to hold frequency data
        analyser.fftSize = 256;
        const bufferLength = analyser.frequencyBinCount;
        dataArray = new Uint8Array(bufferLength);
        
        isAudioInitialized = true;
    }

    function playAudio() {
        if (playlist.length === 0) return;
        initAudioContext();
        
        if (audioCtx.state === 'suspended') {
            audioCtx.resume();
        }
        
        audioPlayer.play();
        isPlaying = true;
        playBtn.innerText = '⏸ Pause';
    }

    function pauseAudio() {
        audioPlayer.pause();
        isPlaying = false;
        playBtn.innerText = '▶ Play';
    }

    playBtn.addEventListener('click', () => {
        if (isPlaying) pauseAudio();
        else playAudio();
    });

    nextBtn.addEventListener('click', () => {
        currentTrackIndex = (currentTrackIndex + 1) % playlist.length;
        loadTrack(currentTrackIndex);
        if (isPlaying) playAudio();
    });

    prevBtn.addEventListener('click', () => {
        currentTrackIndex = (currentTrackIndex - 1 + playlist.length) % playlist.length;
        loadTrack(currentTrackIndex);
        if (isPlaying) playAudio();
    });

    // Update progress bar
    audioPlayer.addEventListener('timeupdate', () => {
        seekBar.value = audioPlayer.currentTime;
        currentTimeEl.innerText = formatTime(audioPlayer.currentTime);
    });

    // Set duration when metadata loads
    audioPlayer.addEventListener('loadedmetadata', () => {
        seekBar.max = audioPlayer.duration;
        durationEl.innerText = formatTime(audioPlayer.duration);
    });

    // Seek functionality
    seekBar.addEventListener('input', () => {
        audioPlayer.currentTime = seekBar.value;
    });

    // Auto-play next song
    audioPlayer.addEventListener('ended', () => {
        nextBtn.click();
    });

    // --- 2. 3D STARFIELD VISUALIZER LOGIC ---
    const canvas = document.getElementById('space-canvas');
    const ctx = canvas.getContext('2d');
    let width, height;
    
    // Star objects
    let stars = [];
    const numStars = 800;
    
    function resize() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    // Create 3D stars
    for (let i = 0; i < numStars; i++) {
        stars.push({
            x: Math.random() * 2000 - 1000,
            y: Math.random() * 2000 - 1000,
            z: Math.random() * 2000,
            size: Math.random() * 1.5 + 0.5
        });
    }

    function drawScene() {
        // Clear background with deep space color and slight trail effect
        ctx.fillStyle = 'rgba(5, 5, 16, 0.2)'; 
        ctx.fillRect(0, 0, width, height);

        let bass = 0;
        let treble = 0;

        // Get Audio Data if playing
        if (isAudioInitialized && !audioPlayer.paused) {
            analyser.getByteFrequencyData(dataArray);
            
            // Calculate Bass (low frequencies make stars move fast)
            for (let i = 0; i < 10; i++) {
                bass += dataArray[i];
            }
            bass = bass / 10; // Average bass

            // Calculate Treble (high frequencies change colors)
            for (let i = 50; i < 100; i++) {
                treble += dataArray[i];
            }
            treble = treble / 50; // Average treble
        }

        // Base speed + bass boost (this is where Rap vs Opera differs!)
        // Calm music = bass around 10-30. Rap = bass around 200+.
        const speed = 2 + (bass * 0.15); 
        
        // Shift colors based on high notes
        const r = Math.min(255, 100 + treble * 2);
        const g = Math.min(255, 200 + (bass * 0.5));
        const b = 255;
        const starColor = `rgb(${r}, ${g}, ${b})`;

        const centerX = width / 2;
        const centerY = height / 2;

        for (let i = 0; i < numStars; i++) {
            let star = stars[i];

            // Move star towards viewer (decrease Z)
            star.z -= speed;

            // If star passes viewer, reset it far away
            if (star.z <= 0) {
                star.z = 2000;
                star.x = Math.random() * 2000 - 1000;
                star.y = Math.random() * 2000 - 1000;
            }

            // 3D to 2D Projection formula
            const fov = 300; // Field of view
            const projectedX = (star.x / star.z) * fov + centerX;
            const projectedY = (star.y / star.z) * fov + centerY;
            const projectedSize = (star.size / star.z) * fov;

            // Draw star
            ctx.fillStyle = starColor;
            ctx.beginPath();
            ctx.arc(projectedX, projectedY, Math.max(0, projectedSize), 0, Math.PI * 2);
            ctx.fill();
            
            // Add a glow effect if bass is high
            if (bass > 150) {
                ctx.shadowBlur = 10;
                ctx.shadowColor = starColor;
            } else {
                ctx.shadowBlur = 0;
            }
        }

        requestAnimationFrame(drawScene);
    }

    // Start animation loop
    drawScene();
</script>

</body>
</html>
